PORT=8004

# MongoDB Atlas: use mongodb+srv:// from Atlas (same cluster is fine; this service uses APPOINTMENT_DB_NAME).
# Example:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# If the URI already includes a path like /mydb, that database is used and APPOINTMENT_DB_NAME is ignored for the path.
MONGO_URI=mongodb://localhost:27017

APPOINTMENT_DB_NAME=appointment-db

# Set to true to fail startup when DB is unavailable.
REQUIRE_DB=false
