# Notification service — Atlas (or local) MongoDB.
# The database name in the URI is rewritten to NOTIFICATION_DB_NAME (default: notification-db).

PORT=8006

# Atlas — replica set connection string (Drivers / Connect in Atlas). URL-encode special chars in the password.
# Example shape (replace USER, PASSWORD, hosts, and DB segment before ?):
# MONGO_URI=mongodb://USER:PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/medilink?tls=true&authSource=admin&retryWrites=true&w=majority
#
# mongodb+srv:// is also fine; the service still forces the database name to notification-db.

MONGO_URI=mongodb://localhost:27017/

NOTIFICATION_DB_NAME=notification-db

# Other MediLink services call this URL (default http://127.0.0.1:8006)
# NOTIFICATION_SERVICE_URL=http://127.0.0.1:8006

NOTIFICATION_INTERNAL_SECRET=replace_with_a_long_random_shared_secret
