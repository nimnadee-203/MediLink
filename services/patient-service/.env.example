PORT=8002

# MongoDB Atlas: paste the connection string from Atlas → Database → Connect → Drivers.
# Use mongodb+srv://... and include the database name before the query string, e.g.:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/medisync?retryWrites=true&w=majority
# URL-encode special characters in USER or PASSWORD (e.g. @ becomes %40).
# In Atlas → Network Access, allow your current IP (or 0.0.0.0/0 for quick local dev only).
MONGO_URI=mongodb://localhost:27017/medisync

# Enforce dedicated databases even when URI points to a different default DB.
PATIENT_DB_NAME=patients
ADMIN_DB_NAME=admin_1
REPORT_DB_NAME=Reports
PATIENT_COLLECTION_NAME=patients
ADMIN_COLLECTION_NAME=admin
REPORT_COLLECTION_NAME=reports

# Comma-separated emails treated as admins by patient-service.
ADMIN_EMAILS=admin@medisync.ai,it23589254@my.sliit.lk

CLERK_SECRET_KEY=sk_test_replace_with_clerk_secret_key
